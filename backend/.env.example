# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/lifeandlimbs

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin Credentials
ADMIN_EMAIL=admin@lifeandlimbs.org
ADMIN_PASSWORD_HASH=   # generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',10))"

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
